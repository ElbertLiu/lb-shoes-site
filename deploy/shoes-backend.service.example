[Unit]
Description=ShoeFactory Backend
After=network.target

[Service]
Type=simple
WorkingDirectory=/var/www/shoefactory/backend
EnvironmentFile=/var/www/shoefactory/backend/.env
ExecStart=/usr/bin/node dist/server.js
Restart=always
RestartSec=5
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
